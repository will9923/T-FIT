{
  "name": "tfit-app",
  "version": "1.8.0",
  "description": "T-FIT - Meu App Personal",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cap:init": "cap init",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "cap:update": "cap update",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "build:cap": "powershell -Command \"if (Test-Path www) { Remove-Item -Recurse -Force www }; New-Item -ItemType Directory -Path www; Get-ChildItem -File | Where-Object { $_.Extension -match 'html|js|css|png|mp4|json|jpeg|webp|gif|svg|ico|webmanifest' } | Copy-Item -Destination www; if (Test-Path assets) { Copy-Item -Recurse assets www }; npx.cmd cap sync\""
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@supabase/supabase-js": "^2.98.0",
    "onesignal-cordova-plugin": "^5.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}